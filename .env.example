# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bot_4_insta
DB_USER=postgres
DB_PASSWORD=your_password_here

# Админы (через запятую)
ADMIN_IDS=123456789
ADMIN_USERNAME=your_username

# Кэш скачиваний (дни)
CACHE_TTL_DAYS=30

# Cobalt API (для скачивания фото и видео)
COBALT_API_URL=http://localhost:9000

# Instagram session (для Stories, получи из cookies браузера)
INSTAGRAM_SESSION_ID=your_session_id_here
