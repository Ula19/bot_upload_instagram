# Токен бота от @BotFather
BOT_TOKEN=

# PostgreSQL (в Docker: DB_HOST=postgres)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=bot_4_insta
DB_USER=bot_user
DB_PASSWORD=changeme

# Админы (через запятую)
ADMIN_IDS=
ADMIN_USERNAME=admin

# Кэш скачиваний (дни)
CACHE_TTL_DAYS=30

# Telegram API (получить на https://my.telegram.org)
# Нужен для Local Bot API
API_ID=
API_HASH=

# Local Bot API (для файлов до 2 ГБ)
LOCAL_BOT_API_URL=http://bot-api:8081

# Cobalt API (в Docker: cobalt — имя сервиса)
COBALT_API_URL=http://cobalt:9000

# Instagram session (для скачивания Stories, получить из cookies браузера)
INSTAGRAM_SESSION_ID=

# Прокси для Instagram API (SSH-туннель: http://host.docker.internal:9999)
# INSTAGRAM_PROXY=
